# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/yonsei_tayo?schema=public"

# JWT (set a long random secret in production)
JWT_SECRET="change-me"

# Email OTP — SMTP_* 는 "발송용 계정 1개"만 설정 (서비스가 메일을 보낼 때 로그인하는 주소)
# 사용자 이메일은 .env에 넣지 않음. 로그인 시 앱에서 입력 → 그 주소로 OTP가 발송됨.
#
# --- 네이버 @naver.com 로 보내기 ---
# 웹메일 → 환경설정 → POP3/IMAP 관리 → SMTP 사용 ✓
# 2단계 인증 켜짐 → MY보안 → 애플리케이션 비밀번호(16자) 발급 → 그 값만 SMTP_PASS (로그인 비밀번호 아님)
# 오류 535 Invalid login → 위 비밀번호 종류/ SMTP 사용 여부 / SMTP_USER 전체 메일 주소 재확인
# 비밀번호에 # $ 등 있으면: SMTP_PASS="여기에16자" 처럼 따옴표
# 실제 메일: OTP_DEBUG_LOG=false | 465 실패 시 PORT=587, SMTP_SECURE=false
#
# Gmail 예시(발송 전용): 앱 비밀번호 발급 후 사용 (일반 비밀번호 불가)
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=465  SMTP_SECURE=true
#
# --- 연세 @yonsei.ac.kr (Microsoft 365) ---
# SMTP_HOST=smtp.office365.com  SMTP_PORT=587  SMTP_SECURE=false
#
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="연타 <noreply@example.com>"

OTP_TTL_MINUTES=10

# Dev: SMTP 없을 때만 터미널에 OTP 출력 (운영에서는 false)
OTP_DEBUG_LOG=false

# Dev: 메일은 보냈지만 연세 메일함에 안 보일 때 터미널에도 OTP 출력
OTP_ECHO_LOG=true

# JWT (개발 중 만료 잦으면 7d 등으로 늘리기)
JWT_EXPIRES_IN=7d

# Retention (daily cron ~4am KST server time)
OTP_RETENTION_DAYS=7
PARTY_RETENTION_DAYS=90
PARTY_AUTO_COMPLETE_HOURS=3

# Trust / no-show
NOSHOW_REPORTS_TO_CONFIRM=2
NOSHOW_SUSPENSION_COUNT=2
SUSPENSION_DAYS=7

# Admin API (웹 관리자 페이지)
ADMIN_API_KEY=yonta-admin-2026
